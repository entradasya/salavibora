<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EntradasYa CRM</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pako/2.1.0/pako.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap');

*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0a0a;
  --surface:#131313;
  --surface2:#1c1c1c;
  --border:#2a2a2a;
  --accent:#cc0000;
  --accent2:#ff3333;
  --text:#f0f0f0;
  --muted:#888;
  --green:#22c55e;
  --yellow:#eab308;
  --blue:#3b82f6;
  --orange:#f97316;
}
body{background:var(--bg);color:var(--text);font-family:'DM Mono',monospace;min-height:100vh}

/* LOGIN */
#login-screen{
  display:flex;align-items:center;justify-content:center;min-height:100vh;
  background:radial-gradient(ellipse at 30% 50%, #1a0000 0%, #0a0a0a 60%);
}
.login-box{
  background:var(--surface);border:1px solid var(--border);
  padding:48px;width:420px;
  box-shadow:0 0 80px rgba(204,0,0,0.15);
}
.login-logo{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--accent);letter-spacing:-1px;margin-bottom:8px}
.login-sub{color:var(--muted);font-size:12px;margin-bottom:40px}
.login-box label{display:block;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.login-box input{
  width:100%;background:#0a0a0a;border:1px solid var(--border);
  color:var(--text);padding:12px 16px;font-family:'DM Mono',monospace;font-size:14px;
  margin-bottom:20px;outline:none;transition:.2s;
}
.login-box input:focus{border-color:var(--accent)}
.login-btn{
  width:100%;background:var(--accent);border:none;color:#fff;
  padding:14px;font-family:'Syne',sans-serif;font-size:15px;font-weight:700;
  cursor:pointer;letter-spacing:1px;text-transform:uppercase;transition:.2s;
}
.login-btn:hover{background:var(--accent2)}
.login-error{color:var(--accent2);font-size:12px;margin-top:12px;display:none}

/* MAIN APP */
#app{display:none;min-height:100vh}

/* TOPBAR */
.topbar{
  background:var(--surface);border-bottom:1px solid var(--border);
  padding:0 24px;height:56px;display:flex;align-items:center;gap:16px;
  position:sticky;top:0;z-index:100;
}
.topbar-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;color:var(--accent);letter-spacing:-0.5px;margin-right:auto}
.topbar-user{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px}
.topbar-role{
  background:var(--accent);color:#fff;font-size:10px;
  padding:3px 8px;font-weight:500;text-transform:uppercase;letter-spacing:1px;
}
.topbar-role.comercial{background:#2a2a2a;color:var(--muted)}
.logout-btn{
  background:none;border:1px solid var(--border);color:var(--muted);
  padding:6px 14px;font-family:'DM Mono',monospace;font-size:11px;cursor:pointer;
  text-transform:uppercase;letter-spacing:1px;transition:.2s;
}
.logout-btn:hover{border-color:var(--accent);color:var(--text)}

/* LAYOUT */
.layout{display:flex;height:calc(100vh - 56px)}
.sidebar{
  width:260px;background:var(--surface);border-right:1px solid var(--border);
  padding:20px 16px;overflow-y:auto;flex-shrink:0;
}
.main{flex:1;overflow-y:auto;padding:24px}

/* SIDEBAR */
.sidebar-section{margin-bottom:24px}
.sidebar-title{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:2px;margin-bottom:12px}
.filter-input{
  width:100%;background:#0a0a0a;border:1px solid var(--border);
  color:var(--text);padding:9px 12px;font-family:'DM Mono',monospace;font-size:12px;
  outline:none;margin-bottom:8px;
}
.filter-input:focus{border-color:var(--accent)}
.filter-select{
  width:100%;background:#0a0a0a;border:1px solid var(--border);
  color:var(--text);padding:9px 12px;font-family:'DM Mono',monospace;font-size:12px;
  outline:none;margin-bottom:8px;cursor:pointer;
}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.stat-box{
  background:#0a0a0a;border:1px solid var(--border);
  padding:10px;text-align:center;
}
.stat-num{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;color:var(--text)}
.stat-label{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:2px}

/* ESTADO BADGES */
.badge{
  display:inline-block;font-size:9px;padding:2px 7px;
  text-transform:uppercase;letter-spacing:1px;font-weight:500;
}
.badge-contactado{background:#1e3a5f;color:#60a5fa}
.badge-interesado{background:#14532d;color:#4ade80}
.badge-no_interesado{background:#450a0a;color:#f87171}
.badge-trabajando{background:#713f12;color:#fbbf24}
.badge-empty{background:#1a1a1a;color:#555;}

/* TABLA */
.table-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:16px;flex-wrap:wrap;gap:12px;
}
.results-count{font-size:12px;color:var(--muted)}
.results-count span{color:var(--text);font-weight:500}
.export-btn{
  background:var(--accent);border:none;color:#fff;
  padding:8px 18px;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;
  cursor:pointer;text-transform:uppercase;letter-spacing:1px;transition:.2s;
}
.export-btn:hover{background:var(--accent2)}
.export-btn:disabled{background:#2a2a2a;color:#555;cursor:not-allowed}

table{width:100%;border-collapse:collapse;font-size:12px}
thead th{
  background:var(--surface2);border-bottom:2px solid var(--accent);
  padding:10px 12px;text-align:left;font-size:10px;text-transform:uppercase;
  letter-spacing:1px;color:var(--muted);white-space:nowrap;cursor:pointer;
  user-select:none;
}
thead th:hover{color:var(--text)}
tbody tr{border-bottom:1px solid var(--border);transition:.15s;cursor:pointer}
tbody tr:hover{background:var(--surface2)}
td{padding:9px 12px;color:var(--text);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
td.nombre-cell{font-weight:500;max-width:220px}
td.email-cell{color:var(--muted);font-size:11px}

/* PAGINATION */
.pagination{
  display:flex;align-items:center;justify-content:center;gap:8px;
  margin-top:20px;padding:16px 0;
}
.page-btn{
  background:var(--surface2);border:1px solid var(--border);color:var(--text);
  padding:7px 14px;font-family:'DM Mono',monospace;font-size:12px;cursor:pointer;
  transition:.2s;min-width:40px;text-align:center;
}
.page-btn:hover{border-color:var(--accent);color:var(--accent)}
.page-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
.page-btn:disabled{opacity:0.3;cursor:not-allowed}
.page-info{font-size:11px;color:var(--muted);padding:0 8px}

/* MODAL */
.modal-overlay{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);
  z-index:1000;align-items:center;justify-content:center;
}
.modal-overlay.open{display:flex}
.modal{
  background:var(--surface);border:1px solid var(--border);
  width:680px;max-width:95vw;max-height:90vh;overflow-y:auto;
  box-shadow:0 0 100px rgba(204,0,0,0.2);
}
.modal-header{
  padding:20px 24px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;background:var(--surface);z-index:1;
}
.modal-nombre{font-family:'Syne',sans-serif;font-size:18px;font-weight:700}
.modal-close{
  background:none;border:1px solid var(--border);color:var(--muted);
  width:32px;height:32px;cursor:pointer;font-size:18px;
  display:flex;align-items:center;justify-content:center;
}
.modal-close:hover{border-color:var(--accent);color:var(--text)}
.modal-body{padding:24px}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px}
.info-item label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:4px}
.info-item a{color:var(--blue);text-decoration:none;font-size:13px;word-break:break-all}
.info-item a:hover{color:var(--accent2)}
.info-item span{font-size:13px;word-break:break-all}
.info-item.full{grid-column:1/-1}
.modal-section{margin-bottom:20px}
.modal-section-title{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.estado-btns{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
.estado-btn{
  background:#1a1a1a;border:1px solid var(--border);color:var(--muted);
  padding:7px 14px;font-family:'DM Mono',monospace;font-size:11px;cursor:pointer;
  text-transform:uppercase;letter-spacing:1px;transition:.2s;
}
.estado-btn:hover{border-color:var(--accent);color:var(--text)}
.estado-btn.active-contactado{background:#1e3a5f;border-color:#3b82f6;color:#60a5fa}
.estado-btn.active-interesado{background:#14532d;border-color:#22c55e;color:#4ade80}
.estado-btn.active-no_interesado{background:#450a0a;border-color:#ef4444;color:#f87171}
.estado-btn.active-trabajando{background:#713f12;border-color:#f97316;color:#fbbf24}
.comercial-input,.notas-input{
  width:100%;background:#0a0a0a;border:1px solid var(--border);
  color:var(--text);padding:10px 14px;font-family:'DM Mono',monospace;font-size:12px;
  outline:none;margin-bottom:8px;resize:vertical;
}
.comercial-input:focus,.notas-input:focus{border-color:var(--accent)}
.notas-input{min-height:80px}
.save-btn{
  background:var(--accent);border:none;color:#fff;
  padding:10px 24px;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;
  cursor:pointer;letter-spacing:1px;text-transform:uppercase;
  transition:.2s;margin-top:8px;
}
.save-btn:hover{background:var(--accent2)}
.save-ok{color:var(--green);font-size:11px;margin-left:12px;display:none}

/* COMERCIAL: aviso sin búsqueda */
.search-required{
  background:#1a1a1a;border:1px solid var(--border);
  padding:40px;text-align:center;color:var(--muted);font-size:13px;
  margin-top:40px;
}
.search-required strong{color:var(--text);display:block;font-family:'Syne',sans-serif;font-size:18px;margin-bottom:8px}

/* LOADING */
.loading{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  height:300px;color:var(--muted);gap:16px;
}
.loading-bar{
  width:200px;height:2px;background:var(--border);overflow:hidden;
}
.loading-bar-inner{
  height:100%;background:var(--accent);
  animation:loading 1.5s ease-in-out infinite;
}
@keyframes loading{0%{width:0;margin-left:0}50%{width:100%;margin-left:0}100%{width:0;margin-left:100%}}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border)}
::-webkit-scrollbar-thumb:hover{background:var(--accent)}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">EntradasYa CRM</div>
    <div class="login-sub">Sala Víbora · Acceso restringido</div>
    <label>Usuario</label>
    <input type="text" id="login-user" placeholder="usuario" autocomplete="off">
    <label>Contraseña</label>
    <input type="password" id="login-pass" placeholder="••••••••" autocomplete="off">
    <button class="login-btn" onclick="doLogin()">Entrar</button>
    <div class="login-error" id="login-error">Usuario o contraseña incorrectos</div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="topbar">
    <div class="topbar-logo">EntradasYa CRM</div>
    <span class="topbar-user" id="topbar-username"></span>
    <span class="topbar-role" id="topbar-role"></span>
    <button class="logout-btn" onclick="doLogout()">Salir</button>
  </div>
  <div class="layout">
    <div class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-title">Buscar</div>
        <input class="filter-input" id="f-nombre" placeholder="Nombre..." oninput="applyFilters()">
        <input class="filter-input" id="f-email" placeholder="Email..." oninput="applyFilters()">
        <input class="filter-input" id="f-ciudad" placeholder="Ciudad..." oninput="applyFilters()">
        <input class="filter-input" id="f-tel" placeholder="Teléfono..." oninput="applyFilters()">
      </div>
      <div class="sidebar-section">
        <div class="sidebar-title">Filtros</div>
        <select class="filter-select" id="f-tipo" onchange="applyFilters()">
          <option value="">Todos los tipos</option>
          <option value="Asociaciones">Asociaciones</option><option value="Beach Clubs y Chiringuitos">Beach Clubs y Chiringuitos</option><option value="Discotecas">Discotecas</option><option value="Espacios Culturales">Espacios Culturales</option><option value="Estadios y Recintos Deportivos">Estadios y Recintos Deportivos</option><option value="Festivales">Festivales</option><option value="Hoteles y Resorts">Hoteles y Resorts</option><option value="Otros Locales">Otros Locales</option><option value="Palacios y Grandes Recintos">Palacios y Grandes Recintos</option><option value="Pubs y Bares">Pubs y Bares</option><option value="Restaurantes">Restaurantes</option><option value="Salas de Conciertos">Salas de Conciertos</option><option value="Teatros">Teatros</option>
        </select>
        <select class="filter-select" id="f-estado" onchange="applyFilters()">
          <option value="">Todos los estados</option>
          <option value="contactado">Contactado</option>
          <option value="interesado">Interesado</option>
          <option value="no_interesado">No interesado</option>
          <option value="trabajando">Trabajando con nosotros</option>
          <option value="">Sin gestionar</option>
        </select>
        <select class="filter-select" id="f-comercial" onchange="applyFilters()">
          <option value="">Todos los comerciales</option>
        </select>
        <button class="export-btn" style="width:100%;margin-top:4px" id="clear-btn" onclick="clearFilters()">Limpiar filtros</button>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-title">Estadísticas</div>
        <div class="stats-grid" id="stats-grid">
          <div class="stat-box"><div class="stat-num" id="s-total">-</div><div class="stat-label">Total</div></div>
          <div class="stat-box"><div class="stat-num" id="s-contactados">-</div><div class="stat-label">Contactados</div></div>
          <div class="stat-box"><div class="stat-num" id="s-interesados">-</div><div class="stat-label">Interesados</div></div>
          <div class="stat-box"><div class="stat-num" id="s-trabajando">-</div><div class="stat-label">Activos</div></div>
        </div>
      </div>
    </div>
    <div class="main">
      <div id="loading-screen" class="loading">
        <div>Cargando base de datos...</div>
        <div class="loading-bar"><div class="loading-bar-inner"></div></div>
      </div>
      <div id="table-area" style="display:none">
        <div class="table-header">
          <div class="results-count">Mostrando <span id="showing-count">0</span> de <span id="total-count">0</span> contactos</div>
          <button class="export-btn" id="export-btn" onclick="exportExcel()">↓ Exportar Excel</button>
        </div>
        <div id="no-search-msg" class="search-required" style="display:none">
          <strong>Introduce un término de búsqueda</strong>
          Usa los filtros de la izquierda para encontrar contactos específicos
        </div>
        <div id="table-wrap">
          <table>
            <thead>
              <tr>
                <th onclick="sortBy('nombre')">Nombre ↕</th>
                <th onclick="sortBy('tipo')">Tipo ↕</th>
                <th onclick="sortBy('ciudad')">Ciudad ↕</th>
                <th>Email</th>
                <th>Teléfono</th>
                <th onclick="sortBy('estado')">Estado ↕</th>
                <th onclick="sortBy('comercial')">Comercial ↕</th>
              </tr>
            </thead>
            <tbody id="table-body"></tbody>
          </table>
          <div class="pagination" id="pagination"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL -->
<div class="modal-overlay" id="modal-overlay" onclick="closeModalOutside(event)">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-nombre" id="m-nombre"></div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="info-grid">
        <div class="info-item"><label>Tipo</label><span id="m-tipo"></span></div>
        <div class="info-item"><label>Ciudad</label><span id="m-ciudad"></span></div>
        <div class="info-item"><label>Teléfono</label><span id="m-tel"></span></div>
        <div class="info-item"><label>Email</label><span id="m-email"></span></div>
        <div class="info-item full"><label>Dirección</label><span id="m-dir"></span></div>
        <div class="info-item full"><label>Web</label><a id="m-web" href="#" target="_blank"></a></div>
      </div>
      <div class="modal-section">
        <div class="modal-section-title">Estado</div>
        <div class="estado-btns">
          <button class="estado-btn" data-estado="contactado" onclick="setEstado('contactado')">✓ Contactado</button>
          <button class="estado-btn" data-estado="interesado" onclick="setEstado('interesado')">★ Interesado</button>
          <button class="estado-btn" data-estado="no_interesado" onclick="setEstado('no_interesado')">✗ No interesado</button>
          <button class="estado-btn" data-estado="trabajando" onclick="setEstado('trabajando')">⚡ Trabajando con nosotros</button>
          <button class="estado-btn" data-estado="" onclick="setEstado('')">↺ Sin estado</button>
        </div>
      </div>
      <div class="modal-section">
        <div class="modal-section-title">Comercial asignado</div>
        <input class="comercial-input" id="m-comercial" placeholder="Nombre del comercial..." type="text">
      </div>
      <div class="modal-section">
        <div class="modal-section-title">Notas</div>
        <textarea class="notas-input" id="m-notas" placeholder="Notas sobre este contacto..."></textarea>
      </div>
      <div class="modal-section">
        <div class="modal-section-title">Fecha de contacto</div>
        <input class="comercial-input" id="m-fecha" type="date">
      </div>
      <button class="save-btn" onclick="saveContact()">Guardar</button>
      <span class="save-ok" id="save-ok">✓ Guardado</span>
      <button class="save-btn" style="background:#1a1a1a;border:1px solid var(--border);color:var(--muted);margin-left:8px" onclick="closeModal()">Cancelar</button>
    </div>
  </div>
</div>

<script>
// ====== USERS CONFIG ======
const USERS = {
  "dani": { pass: "vibora2024admin", role: "admin", name: "Dani (Admin)" },
  "comercial1": { pass: "comercial2024", role: "comercial", name: "Comercial" },
};

// ====== STATE ======
let allContacts = [];
let filteredContacts = [];
let currentPage = 1;
const PAGE_SIZE = 50;
let sortField = 'nombre';
let sortDir = 1;
let currentContact = null;
let currentUser = null;
let loaded = false;

// ====== LOGIN ======
function doLogin() {
  const u = document.getElementById('login-user').value.trim().toLowerCase();
  const p = document.getElementById('login-pass').value;
  if (USERS[u] && USERS[u].pass === p) {
    currentUser = { ...USERS[u], username: u };
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    document.getElementById('topbar-username').textContent = currentUser.name;
    const roleEl = document.getElementById('topbar-role');
    roleEl.textContent = currentUser.role === 'admin' ? 'Admin' : 'Comercial';
    if (currentUser.role === 'comercial') roleEl.classList.add('comercial');
    if (currentUser.role === 'admin') {
      document.getElementById('export-btn').disabled = false;
    } else {
      document.getElementById('export-btn').disabled = true;
      document.getElementById('export-btn').style.display = 'none';
    }
    if (!loaded) loadContacts();
  } else {
    const err = document.getElementById('login-error');
    err.style.display = 'block';
    setTimeout(() => err.style.display = 'none', 3000);
  }
}

document.getElementById('login-pass').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });
document.getElementById('login-user').addEventListener('keydown', e => { if(e.key==='Enter') document.getElementById('login-pass').focus(); });

function doLogout() {
  currentUser = null;
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('login-user').value = '';
  document.getElementById('login-pass').value = '';
}

// ====== LOAD DATA ======
const CONTACTS_B64 = "";

async function loadContacts() {
  try {
    const binary = atob(CONTACTS_B64);
    const bytes = new Uint8Array(binary.length);
    for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
    const decompressed = pako.inflate(bytes, { to: 'string' });
    const raw = JSON.parse(decompressed);
    
    // Merge with localStorage overrides
    const saved = JSON.parse(localStorage.getItem('crm_overrides') || '{}');
    allContacts = raw.map(c => {
      const override = saved[c.id] || {};
      return { ...c, ...override };
    });
    
    loaded = true;
    document.getElementById('loading-screen').style.display = 'none';
    document.getElementById('table-area').style.display = 'block';
    updateStats();
    updateComercialFilter();
    applyFilters();
  } catch(e) {
    document.getElementById('loading-screen').innerHTML = '<div style="color:#f87171">Error cargando datos: ' + e.message + '</div>';
  }
}

// ====== FILTERS ======
function hasActiveFilter() {
  return document.getElementById('f-nombre').value.trim() ||
         document.getElementById('f-email').value.trim() ||
         document.getElementById('f-ciudad').value.trim() ||
         document.getElementById('f-tel').value.trim() ||
         document.getElementById('f-tipo').value ||
         document.getElementById('f-estado').value ||
         document.getElementById('f-comercial').value;
}

function applyFilters() {
  const nombre = document.getElementById('f-nombre').value.trim().toLowerCase();
  const email = document.getElementById('f-email').value.trim().toLowerCase();
  const ciudad = document.getElementById('f-ciudad').value.trim().toLowerCase();
  const tel = document.getElementById('f-tel').value.trim().toLowerCase();
  const tipo = document.getElementById('f-tipo').value;
  const estado = document.getElementById('f-estado').value;
  const comercial = document.getElementById('f-comercial').value.toLowerCase();

  const isComercial = currentUser && currentUser.role === 'comercial';
  const active = hasActiveFilter();

  if (isComercial && !active) {
    document.getElementById('no-search-msg').style.display = 'block';
    document.getElementById('table-wrap').style.display = 'none';
    document.getElementById('showing-count').textContent = '0';
    document.getElementById('total-count').textContent = allContacts.length;
    return;
  }
  document.getElementById('no-search-msg').style.display = 'none';
  document.getElementById('table-wrap').style.display = 'block';

  filteredContacts = allContacts.filter(c => {
    if (nombre && !c.nombre.toLowerCase().includes(nombre)) return false;
    if (email && !c.email.toLowerCase().includes(email)) return false;
    if (ciudad && !c.ciudad.toLowerCase().includes(ciudad)) return false;
    if (tel && !c.telefono.toLowerCase().includes(tel)) return false;
    if (tipo && c.tipo !== tipo) return false;
    if (estado !== undefined && estado !== '' && c.estado !== estado) return false;
    if (comercial && !c.comercial.toLowerCase().includes(comercial)) return false;
    return true;
  });

  // Sort
  filteredContacts.sort((a, b) => {
    const va = (a[sortField] || '').toLowerCase();
    const vb = (b[sortField] || '').toLowerCase();
    return va < vb ? -sortDir : va > vb ? sortDir : 0;
  });

  currentPage = 1;
  document.getElementById('showing-count').textContent = filteredContacts.length;
  document.getElementById('total-count').textContent = allContacts.length;
  renderTable();
  renderPagination();
}

function clearFilters() {
  ['f-nombre','f-email','f-ciudad','f-tel'].forEach(id => document.getElementById(id).value = '');
  ['f-tipo','f-estado','f-comercial'].forEach(id => document.getElementById(id).value = '');
  applyFilters();
}

function sortBy(field) {
  if (sortField === field) sortDir *= -1;
  else { sortField = field; sortDir = 1; }
  applyFilters();
}

// ====== RENDER ======
function estadoBadge(estado) {
  if (!estado) return '<span class="badge badge-empty">Sin gestionar</span>';
  const labels = { contactado:'Contactado', interesado:'Interesado', no_interesado:'No interesado', trabajando:'Activo' };
  return `<span class="badge badge-${estado}">${labels[estado] || estado}</span>`;
}

function renderTable() {
  const tbody = document.getElementById('table-body');
  const start = (currentPage - 1) * PAGE_SIZE;
  const page = filteredContacts.slice(start, start + PAGE_SIZE);
  tbody.innerHTML = page.map(c => `
    <tr onclick="openModal(${c.id})">
      <td class="nombre-cell" title="${c.nombre}">${c.nombre}</td>
      <td title="${c.tipo}">${c.tipo || '—'}</td>
      <td>${c.ciudad || '—'}</td>
      <td class="email-cell" title="${c.email}">${c.email || '—'}</td>
      <td>${c.telefono || '—'}</td>
      <td>${estadoBadge(c.estado)}</td>
      <td style="color:var(--muted);font-size:11px">${c.comercial || '—'}</td>
    </tr>
  `).join('');
}

function renderPagination() {
  const total = Math.ceil(filteredContacts.length / PAGE_SIZE);
  if (total <= 1) { document.getElementById('pagination').innerHTML = ''; return; }
  
  let pages = [];
  pages.push(`<button class="page-btn" ${currentPage===1?'disabled':''} onclick="goPage(${currentPage-1})">‹</button>`);
  
  const range = [];
  for (let i = 1; i <= total; i++) {
    if (i === 1 || i === total || (i >= currentPage-2 && i <= currentPage+2)) range.push(i);
    else if (range[range.length-1] !== '...') range.push('...');
  }
  range.forEach(p => {
    if (p === '...') pages.push(`<span class="page-info">...</span>`);
    else pages.push(`<button class="page-btn ${p===currentPage?'active':''}" onclick="goPage(${p})">${p}</button>`);
  });
  
  pages.push(`<button class="page-btn" ${currentPage===total?'disabled':''} onclick="goPage(${currentPage+1})">›</button>`);
  document.getElementById('pagination').innerHTML = pages.join('');
}

function goPage(p) {
  currentPage = p;
  renderTable();
  renderPagination();
  document.querySelector('.main').scrollTop = 0;
}

// ====== STATS ======
function updateStats() {
  document.getElementById('s-total').textContent = allContacts.length.toLocaleString();
  document.getElementById('s-contactados').textContent = allContacts.filter(c => c.estado).length.toLocaleString();
  document.getElementById('s-interesados').textContent = allContacts.filter(c => c.estado === 'interesado').length.toLocaleString();
  document.getElementById('s-trabajando').textContent = allContacts.filter(c => c.estado === 'trabajando').length.toLocaleString();
}

function updateComercialFilter() {
  const comerciales = [...new Set(allContacts.map(c => c.comercial).filter(Boolean))].sort();
  const sel = document.getElementById('f-comercial');
  const current = sel.value;
  sel.innerHTML = '<option value="">Todos los comerciales</option>' + 
    comerciales.map(c => `<option value="${c}" ${c===current?'selected':''}>${c}</option>`).join('');
}

// ====== MODAL ======
function openModal(id) {
  currentContact = allContacts.find(c => c.id === id);
  if (!currentContact) return;
  document.getElementById('m-nombre').textContent = currentContact.nombre;
  document.getElementById('m-tipo').textContent = currentContact.tipo || '—';
  document.getElementById('m-ciudad').textContent = currentContact.ciudad || '—';
  document.getElementById('m-tel').textContent = currentContact.telefono || '—';
  document.getElementById('m-email').textContent = currentContact.email || '—';
  document.getElementById('m-dir').textContent = currentContact.direccion || '—';
  const webEl = document.getElementById('m-web');
  if (currentContact.web) { webEl.href = currentContact.web; webEl.textContent = currentContact.web; }
  else { webEl.textContent = '—'; webEl.href = '#'; }
  document.getElementById('m-comercial').value = currentContact.comercial || '';
  document.getElementById('m-notas').value = currentContact.notas || '';
  document.getElementById('m-fecha').value = currentContact.fecha_contacto || '';
  
  // If comercial: auto-set comercial field
  if (currentUser.role === 'comercial' && !currentContact.comercial) {
    document.getElementById('m-comercial').value = currentUser.name;
  }
  
  // Update estado buttons
  document.querySelectorAll('.estado-btn').forEach(btn => {
    const e = btn.dataset.estado;
    btn.className = 'estado-btn';
    if (e && e === currentContact.estado) btn.classList.add('active-' + e);
  });
  
  document.getElementById('save-ok').style.display = 'none';
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  currentContact = null;
}

function closeModalOutside(e) {
  if (e.target === document.getElementById('modal-overlay')) closeModal();
}

function setEstado(estado) {
  if (!currentContact) return;
  currentContact.estado = estado;
  document.querySelectorAll('.estado-btn').forEach(btn => {
    const e = btn.dataset.estado;
    btn.className = 'estado-btn';
    if (e && e === estado) btn.classList.add('active-' + e);
  });
}

function saveContact() {
  if (!currentContact) return;
  currentContact.comercial = document.getElementById('m-comercial').value.trim();
  currentContact.notas = document.getElementById('m-notas').value.trim();
  currentContact.fecha_contacto = document.getElementById('m-fecha').value;
  
  // Save to localStorage
  const saved = JSON.parse(localStorage.getItem('crm_overrides') || '{}');
  saved[currentContact.id] = {
    estado: currentContact.estado,
    comercial: currentContact.comercial,
    notas: currentContact.notas,
    fecha_contacto: currentContact.fecha_contacto
  };
  localStorage.setItem('crm_overrides', JSON.stringify(saved));
  
  // Update in allContacts
  const idx = allContacts.findIndex(c => c.id === currentContact.id);
  if (idx >= 0) allContacts[idx] = { ...allContacts[idx], ...saved[currentContact.id] };
  
  updateStats();
  updateComercialFilter();
  renderTable();
  
  const ok = document.getElementById('save-ok');
  ok.style.display = 'inline';
  setTimeout(() => ok.style.display = 'none', 2000);
}

// ====== EXPORT (admin only) ======
function exportExcel() {
  if (!currentUser || currentUser.role !== 'admin') return;
  const data = filteredContacts.map(c => ({
    'Nombre': c.nombre,
    'Tipo': c.tipo,
    'Ciudad': c.ciudad,
    'Teléfono': c.telefono,
    'Email': c.email,
    'Dirección': c.direccion,
    'Web': c.web,
    'Estado': c.estado,
    'Comercial': c.comercial,
    'Notas': c.notas,
    'Fecha contacto': c.fecha_contacto
  }));
  const ws = XLSX.utils.json_to_sheet(data);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Contactos');
  XLSX.writeFile(wb, 'entradasya_contactos.xlsx');
}

// ESC close modal
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
